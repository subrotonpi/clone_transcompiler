    "def msd(df, idlist):\n",
    "    x = []\n",
    "    for ii, rr in df.iterrows():\n",
    "        k = (int(rr.id))\n",
    "        if k in idlist:\n",
    "            x+=[rr.dist]\n",
    "    return mean(x), stdev(x)"
   ]
